{
  "annotations": {"list": []},
  "description": "Mopro SLO Overview — API availability, latency, saturation, and traffic",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mopro", "slo"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(mopro_http_requests_total, service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": {"query": "label_values(mopro_http_requests_total, service)", "refId": "service"},
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Service"
      },
      {
        "current": {"selected": false, "text": "1m", "value": "1m"},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "interval",
        "options": [
          {"selected": false, "text": "30s", "value": "30s"},
          {"selected": true,  "text": "1m",  "value": "1m"},
          {"selected": false, "text": "5m",  "value": "5m"},
          {"selected": false, "text": "10m", "value": "10m"}
        ],
        "query": "30s,1m,5m,10m",
        "type": "custom",
        "label": "Interval"
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SLO Overview",
  "uid": "mopro-slo-overview",
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Row 1 — Availability",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.5}
            ]
          },
          "unit": "percent",
          "min": 95,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "100 * (1 - sum by (service) (rate(mopro_http_requests_total{service=~\"$service\",status=~\"5..\"}[30d])) / clamp_min(sum by (service) (rate(mopro_http_requests_total{service=~\"$service\",status!~\"4..\"}[30d])), 1))",
          "instant": true,
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "API Availability 30d",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (service) (rate(mopro_http_requests_total{service=~\"$service\",status=~\"5..\"}[$interval])) / clamp_min(sum by (service) (rate(mopro_http_requests_total{service=~\"$service\"}[$interval])), 0.001)",
          "instant": true,
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "5xx Rate (current $interval)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 16, "x": 0, "y": 5},
      "id": 4,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (service) (rate(mopro_http_requests_total{service=~\"$service\",status=~\"5..\"}[$interval])) / clamp_min(sum by (service) (rate(mopro_http_requests_total{service=~\"$service\"}[$interval])), 0.001)",
          "legendFormat": "{{service}} 5xx",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 5},
      "id": 5,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (service) (rate(mopro_http_requests_total{service=~\"$service\"}[$interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Requests/sec by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 12},
      "id": 10,
      "title": "Row 2 — Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.25},
              {"color": "red", "value": 0.5}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 13},
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (le, service) (rate(mopro_http_request_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "instant": true,
          "legendFormat": "{{service}} p50",
          "refId": "A"
        }
      ],
      "title": "Latency p50",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.3},
              {"color": "red", "value": 0.5}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 13},
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(mopro_http_request_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "instant": true,
          "legendFormat": "{{service}} p95",
          "refId": "A"
        }
      ],
      "title": "Latency p95 (SLO: < 500ms)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 13},
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(mopro_http_request_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "instant": true,
          "legendFormat": "{{service}} p99",
          "refId": "A"
        }
      ],
      "title": "Latency p99 (SLO: < 2s)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 18, "x": 0, "y": 17},
      "id": 14,
      "options": {
        "legend": {"calcs": ["mean", "max", "p95"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (le, service) (rate(mopro_http_request_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "legendFormat": "{{service}} p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(mopro_http_request_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "legendFormat": "{{service}} p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(mopro_http_request_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "legendFormat": "{{service}} p99",
          "refId": "C"
        }
      ],
      "title": "Latency Distribution (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 20,
      "title": "Row 3 — Saturation",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "percentunit",
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 25},
      "id": 21,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_pgx_pool_acquired_conns / clamp_min(mopro_pgx_pool_max_conns, 1)",
          "legendFormat": "{{service}}/{{db}} pool",
          "refId": "A"
        }
      ],
      "title": "DB Pool Utilization (acquired / max)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 25},
      "id": 22,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(mopro_db_query_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "legendFormat": "{{service}} DB p95",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(mopro_redis_command_duration_seconds_bucket{service=~\"$service\"}[$interval])))",
          "legendFormat": "{{service}} Redis p95",
          "refId": "B"
        }
      ],
      "title": "DB + Redis Query Latency p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "id": 30,
      "title": "Row 4 — Traffic",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "spanNulls": true},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 33},
      "id": 31,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (service) (rate(mopro_http_requests_total{service=~\"$service\"}[$interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Total Requests/sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"displayMode": "auto"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [{"id": "displayName", "value": "req/s"}]
          }
        ]
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 33},
      "id": 32,
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"displayName": "req/s", "desc": true}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, sum by (service, route) (rate(mopro_http_requests_total{service=~\"$service\"}[$interval])))",
          "instant": true,
          "legendFormat": "{{service}} {{route}}",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Top 10 Routes by Volume",
      "transformations": [
        {"id": "sortBy", "options": {"fields": [{"desc": true, "displayName": "Value"}]}}
      ],
      "type": "table"
    }
  ]
}
