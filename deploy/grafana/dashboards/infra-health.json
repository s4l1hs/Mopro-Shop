{
  "annotations": {"list": []},
  "description": "Mopro Infrastructure Health — Postgres, Redis, Caddy, VDS host metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mopro", "infra"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {"selected": false, "text": "1m", "value": "1m"},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "interval",
        "options": [
          {"selected": false, "text": "30s", "value": "30s"},
          {"selected": true,  "text": "1m",  "value": "1m"},
          {"selected": false, "text": "5m",  "value": "5m"}
        ],
        "query": "30s,1m,5m",
        "type": "custom",
        "label": "Interval"
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Infra Health",
  "uid": "mopro-infra",
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Row 1 — PostgreSQL",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_pgx_pool_acquired_conns",
          "legendFormat": "{{service}}/{{db}} acquired",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_pgx_pool_max_conns",
          "legendFormat": "{{service}}/{{db}} max",
          "refId": "B"
        }
      ],
      "title": "PgBouncer Pool: Acquired vs Max",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.8},
              {"color": "red", "value": 0.95}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_pgx_pool_acquired_conns / clamp_min(mopro_pgx_pool_max_conns, 1)",
          "legendFormat": "{{service}}/{{db}} utilization",
          "refId": "A"
        }
      ],
      "title": "Pool Utilization (acquired / max)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "spanNulls": true},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 8},
      "id": 4,
      "options": {
        "legend": {"calcs": ["mean", "p95", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, service, op) (rate(mopro_db_query_duration_seconds_bucket[$interval])))",
          "legendFormat": "{{service}} {{op}} p95",
          "refId": "A"
        }
      ],
      "title": "DB Query Latency p95 by Service + Operation",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 10,
      "title": "Row 2 — Redis",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 16},
      "id": 11,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(mopro_redis_command_duration_seconds_bucket[$interval])))",
          "legendFormat": "{{service}} Redis p95",
          "refId": "A"
        }
      ],
      "title": "Redis Command Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "spanNulls": true},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 16},
      "id": 12,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (service, cmd) (rate(mopro_redis_command_duration_seconds_count[$interval]))",
          "legendFormat": "{{service}} {{cmd}}",
          "refId": "A"
        }
      ],
      "title": "Redis Ops/sec by Command",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "id": 20,
      "title": "Row 3 — VDS Host (node_exporter)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "percentunit",
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 24},
      "id": 21,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "1 - avg by (cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[$interval]))",
          "legendFormat": "CPU {{cpu}}",
          "refId": "A"
        }
      ],
      "title": "CPU Utilization per Core (node_exporter)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.8},
              {"color": "red", "value": 0.92}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 24},
      "id": 22,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=~\"/|/var\"} / node_filesystem_size_bytes{mountpoint=~\"/|/var\"})",
          "legendFormat": "{{mountpoint}} used",
          "refId": "A"
        }
      ],
      "title": "Disk Usage % by Mountpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "spanNulls": true},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 31},
      "id": 23,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[$interval])",
          "legendFormat": "TX {{device}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[$interval])",
          "legendFormat": "RX {{device}}",
          "refId": "B"
        }
      ],
      "title": "Network Throughput (TX/RX)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
      "id": 30,
      "title": "Row 4 — Event Bus & Outbox",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 39},
      "id": 31,
      "options": {
        "legend": {"calcs": ["last", "sum"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (service, outcome) (rate(mopro_eventbus_messages_processed_total[$interval]))",
          "legendFormat": "{{service}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Event Bus Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 39},
      "id": 32,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_outbox_lag_seconds",
          "legendFormat": "{{service}} outbox lag",
          "refId": "A"
        }
      ],
      "title": "Outbox Publisher Lag",
      "type": "timeseries"
    }
  ]
}
