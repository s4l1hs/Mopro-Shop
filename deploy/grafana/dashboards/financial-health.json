{
  "annotations": {"list": []},
  "description": "Mopro Financial Health — GMV, orders, cashback, ledger reconcile, PSP",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["mopro", "finance"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {"selected": false, "text": "1h", "value": "1h"},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "interval",
        "options": [
          {"selected": false, "text": "10m", "value": "10m"},
          {"selected": true,  "text": "1h",  "value": "1h"},
          {"selected": false, "text": "6h",  "value": "6h"}
        ],
        "query": "10m,1h,6h",
        "type": "custom",
        "label": "Interval"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "Europe/Istanbul",
  "title": "Financial Health",
  "uid": "mopro-financial",
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Row 1 — Revenue & Orders",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "increase(mopro_order_status_transitions_total{to=\"captured\"}[24h])",
          "instant": true,
          "legendFormat": "orders captured",
          "refId": "A"
        }
      ],
      "title": "Orders Captured (24h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "increase(mopro_orderledger_postings_total[24h])",
          "instant": true,
          "legendFormat": "ledger postings",
          "refId": "A"
        }
      ],
      "title": "Ledger Postings (24h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.7}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(mopro_order_status_transitions_total{from=\"pending_payment\",to=\"captured\"}[1h])) / clamp_min(sum(rate(mopro_order_status_transitions_total{from=\"created\",to=\"pending_payment\"}[1h])), 0.0001)",
          "instant": true,
          "legendFormat": "conversion rate",
          "refId": "A"
        }
      ],
      "title": "Checkout Conversion Rate (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 5},
      "id": 5,
      "options": {
        "legend": {"calcs": ["last", "sum"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (to) (increase(mopro_order_status_transitions_total[$interval]))",
          "legendFormat": "→ {{to}}",
          "refId": "A"
        }
      ],
      "title": "Order Status Transitions per $interval",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 12},
      "id": 10,
      "title": "Row 2 — Cashback Engine",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "purple", "value": null}]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 13},
      "id": 11,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "increase(mopro_cashback_plans_created_total[24h])",
          "instant": true,
          "legendFormat": "plans created",
          "refId": "A"
        }
      ],
      "title": "Cashback Plans Created (24h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "purple", "value": null}]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 13},
      "id": 12,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "increase(mopro_cashback_installments_paid_total[30d])",
          "instant": true,
          "legendFormat": "installments paid",
          "refId": "A"
        }
      ],
      "title": "Cashback Installments Paid (30d)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "FAILED"}, "1": {"color": "green", "text": "OK"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 13},
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_job_last_run_status{job=\"cashback-monthly\"}",
          "instant": true,
          "legendFormat": "cashback-monthly",
          "refId": "A"
        }
      ],
      "title": "Cashback Monthly Cron — Last Status",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 17},
      "id": 14,
      "options": {
        "legend": {"calcs": ["last", "sum"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (market) (increase(mopro_cashback_installments_paid_total[$interval]))",
          "legendFormat": "{{market}} installments",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (market) (increase(mopro_cashback_plans_created_total[$interval]))",
          "legendFormat": "{{market}} plans created",
          "refId": "B"
        }
      ],
      "title": "Cashback Activity per $interval",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 20,
      "title": "Row 3 — Ledger Reconcile",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "IMBALANCED ⚠"}, "1": {"color": "green", "text": "BALANCED ✓"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 25},
      "id": 21,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_job_last_run_status{job=\"ledger-reconcile\"}",
          "instant": true,
          "legendFormat": "Ledger Balance",
          "refId": "A"
        }
      ],
      "title": "Last Reconcile Status",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          },
          "unit": "dateTimeFromNow"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 25},
      "id": 22,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "mopro_job_last_run_timestamp_seconds{job=\"ledger-reconcile\"} * 1000",
          "instant": true,
          "legendFormat": "last run",
          "refId": "A"
        }
      ],
      "title": "Last Reconcile Time",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 29},
      "id": 30,
      "title": "Row 4 — PSP (Sipay)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.85},
              {"color": "green", "value": 0.95}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 30},
      "id": 31,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "1 - sum(rate(sipay_request_total{status!~\"2.*\"}[$interval])) / clamp_min(sum(rate(sipay_request_total[$interval])), 0.0001)",
          "instant": true,
          "legendFormat": "success rate",
          "refId": "A"
        }
      ],
      "title": "Sipay 3DS Success Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 30},
      "id": 32,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sipay_request_duration_seconds_bucket[$interval])))",
          "instant": true,
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Sipay API Latency p95",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "hideFrom": {"legend": false, "tooltip": false, "viz": false}
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 30},
      "id": 33,
      "options": {
        "legend": {"displayMode": "table", "placement": "right"},
        "pieType": "pie",
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (status) (increase(sipay_request_total[$interval]))",
          "instant": true,
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Sipay Request Status Breakdown",
      "type": "piechart"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "spanNulls": true},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 34},
      "id": 34,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(sipay_request_duration_seconds_bucket[$interval])))",
          "legendFormat": "{{endpoint}} p95",
          "refId": "A"
        }
      ],
      "title": "Sipay Latency p95 by Endpoint",
      "type": "timeseries"
    }
  ]
}
