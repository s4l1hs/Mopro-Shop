{
	email {$CADDY_EMAIL}
	# TODO(production): add trusted_proxies cloudflare once CF IP range is confirmed
	# trusted_proxies cloudflare
}

# ─── Snippets (imported by production + dev site blocks) ─────────────────────

# Native Caddy health endpoint — does NOT proxy to any backend.
# Used by Docker healthcheck and smoke tests.
(healthz_native) {
	handle /healthz {
		respond "OK" 200
	}
}

# fin-svc owns: wallet reads, cashback reads, payout reads, admin
# ARCHITECTURE.md § 4.2 — fin-svc HTTP server: wallet/cashback/payout read
# fin-svc listens on :8081 (core-svc and jobs-svc on :8080)
(fin_routes) {
	handle /wallet/* {
		reverse_proxy fin-svc:8081
	}
	handle /cashback/* {
		reverse_proxy fin-svc:8081
	}
	handle /payouts/* {
		reverse_proxy fin-svc:8081
	}
	handle /admin/* {
		reverse_proxy fin-svc:8081
	}
}

# jobs-svc owns: notifications, media, support, sizefinder, antifraud-inference
(jobs_routes) {
	handle /jobs/* {
		reverse_proxy jobs-svc:8080
	}
}

# ─── Staging: api-staging.moproshop.com ──────────────────────────────────────
# Identical routing to production. DNS A record must point to the same VDS IP.
# Staging-specific env vars are set via .env.staging (sourced before docker compose up).
# OTP bypass: set DEV_OTP_ACCEPT_ANY=true in .env.staging for smoke test flows.
api-staging.moproshop.com {
	import healthz_native
	import fin_routes
	import jobs_routes

	@psp_webhook path /payments/webhook/*
	handle @psp_webhook {
		reverse_proxy core-svc:8080
	}

	@shipping_webhook path /shipping/webhook/*
	handle @shipping_webhook {
		reverse_proxy core-svc:8080
	}

	handle {
		reverse_proxy core-svc:8080
	}
}

# ─── Staging: staging.moproshop.com ──────────────────────────────────────────
staging.moproshop.com {
	import healthz_native
	respond "Staging — Çok yakında" 200
}

# ─── Production: api.moproshop.com ───────────────────────────────────────────
api.moproshop.com {
	# TODO(production): CloudFlare-only enforcer.
	# Reject requests that do not carry CF-Connecting-IP (traffic that bypassed
	# CloudFlare and hit the VDS IP directly). UFW must also block direct :80/:443
	# access from non-CF IPs. Uncomment after verifying CF IP ranges.
	# @not_cf {
	#     not header CF-Connecting-IP *
	# }
	# respond @not_cf "Forbidden" 403

	import healthz_native
	import fin_routes
	import jobs_routes

	# ── PSP payment webhooks — NO middleware, HMAC verified in handler ────────
	# Phase 1.5: Explicit route so future auth / rate-limit middleware does NOT
	# apply to Sipay/Craftgate/iyzico inbound callbacks. Signature verification
	# is provider-specific (CLAUDE.md § 9):
	#   Sipay:      hash_key = base64(SHA512(merchant_key + status_code + invoice_id + amount + currency))
	#   Craftgate:  x-craftgate-signature = HMAC-SHA256(rawBody, webhook_secret)
	#   iyzico:     no header signature; verify via paymentId server-side lookup
	@psp_webhook path /payments/webhook/*
	handle @psp_webhook {
		# NO rate_limit, NO @cf_only enforcer applied to PSP webhooks.
		# The webhook handler itself verifies the provider HMAC signature.
		reverse_proxy core-svc:8080
	}

	# ── Shipping carrier webhooks ─────────────────────────────────────────────
	# NO rate-limit / auth middleware — signature verification is carrier-specific
	# and handled inside shippingService.HandleWebhook (HMAC for Sürat/MNG,
	# Bearer token for HepsiJet). "delivered" triggers ecom.order.delivered.v1.
	@shipping_webhook path /shipping/webhook/*
	handle @shipping_webhook {
		reverse_proxy core-svc:8080
	}

	# ── Seller transparency endpoint ──────────────────────────────────────────
	# GET /seller/orders/:id/breakdown → core-svc (CLAUDE.md § 4.8)

	# TODO(rate-limit-sprint): caddy-ratelimit plugin required (xcaddy custom build).
	# rate_limit {
	#     zone api_per_ip {
	#         key     {client_ip}
	#         window  1m
	#         max     600
	#     }
	# }

	# Default: all /* not matched above → core-svc
	handle {
		reverse_proxy core-svc:8080
	}
}

# ─── Production: seller.moproshop.com ────────────────────────────────────────
seller.moproshop.com {
	# TODO(production): CloudFlare-only enforcer (same pattern as api block above)

	import healthz_native

	# Seller panel SPA + transparency endpoints (ARCHITECTURE.md § 6)
	# Primary: GET /seller/orders/{id}/breakdown  (CLAUDE.md § 4.8)
	reverse_proxy core-svc:8080
}

# ─── Production: moproshop.com + www.moproshop.com ──────────────────────────
# Flutter Web (ADR-0005): the consumer storefront is the release `flutter build
# web` output, static-served here (SPA fallback to index.html). The web client
# calls the API at api.moproshop.com → core-svc, exactly like the mobile app.
# The build is shipped to /srv/web on the VDS by CI (deploy cutover is gated).
moproshop.com, www.moproshop.com {
	import healthz_native
	root * /srv/web
	encode gzip zstd
	try_files {path} /index.html
	file_server
}

# ─── Production: admin.moproshop.com ─────────────────────────────────────────
# Internal admin panel. Phase 4.0.5: returns 503.
# Phase N: restrict to VPN/office CIDRs before wiring to any backend.
admin.moproshop.com {
	import healthz_native
	respond "Service Unavailable" 503
}

# ─── Production: fin.moproshop.com ───────────────────────────────────────────
# fin-svc read endpoints (wallet / cashback / payouts). Phase 4.0.5: returns 404.
# Phase N: restrict to authenticated internal callers before proxying fin-svc.
fin.moproshop.com {
	import healthz_native
	respond "Not Found" 404
}

