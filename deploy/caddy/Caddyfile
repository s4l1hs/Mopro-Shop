# ─── Dev: api.localhost — HTTPS, Caddy internal CA ────────────────────────────
# Caddy issues a self-signed cert for api.localhost.
# Trust the CA once: caddy trust  (or copy /data/caddy/pki/... into system trust store)
# Use curl -k or --cacert to skip verification in CI.
api.localhost {
	tls internal

	import healthz_native
	import fin_routes
	import jobs_routes

	# TODO(Phase 1.5): rate_limit — xcaddy required

	reverse_proxy core-svc:8080
}

# ─── Dev: seller.localhost — HTTPS, Caddy internal CA ─────────────────────────
seller.localhost {
	tls internal

	import healthz_native

	# Seller panel + transparency endpoint
	reverse_proxy core-svc:8080
}

# ─── Plain HTTP: localhost:80 ────────────────────────────────────────────────
# Explicit port in the address disables Caddy's auto-HTTPS and HTTP→HTTPS
# redirects for this site. Used by the Docker container healthcheck
# (wget -qO- http://localhost/healthz) and plain-HTTP smoke tests.
localhost:80 {
	handle /healthz {
		respond "OK" 200
	}

	@fin path /v1/wallet/* /v1/cashback/* /v1/payouts/* /v1/admin/*
	handle @fin {
		reverse_proxy fin-svc:8080
	}

	@jobs path /v1/jobs/*
	handle @jobs {
		reverse_proxy jobs-svc:8080
	}

	handle {
		reverse_proxy core-svc:8080
	}
}
