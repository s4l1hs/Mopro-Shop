# ─── Dev: api.localhost — HTTPS, Caddy internal CA ────────────────────────────
# Caddy issues a self-signed cert for api.localhost.
# Trust the CA once: caddy trust  (or copy /data/caddy/pki/... into system trust store)
# Use curl -k or --cacert to skip verification in CI.
api.localhost {
	tls internal

	import healthz_native
	import fin_routes
	import jobs_routes

	# ── PSP payment webhooks — NO middleware, HMAC verified in handler ────────
	@psp_webhook path /payments/webhook/*
	handle @psp_webhook {
		# NO rate_limit, NO @cf_only enforcer applied to PSP webhooks.
		# The webhook handler itself verifies the provider HMAC signature.
		reverse_proxy core-svc:8080
	}

	# ── Shipping carrier webhooks ─────────────────────────────────────────────
	@shipping_webhook path /shipping/webhook/*
	handle @shipping_webhook {
		reverse_proxy core-svc:8080
	}

	# TODO(rate-limit-sprint): caddy-ratelimit plugin required (xcaddy custom build)
	# rate_limit { zone api_per_ip { key {client_ip}; window 1m; max 600 } }

	# Default: all /* not matched above → core-svc
	handle {
		reverse_proxy core-svc:8080
	}
}

# ─── Dev: seller.localhost — HTTPS, Caddy internal CA ─────────────────────────
seller.localhost {
	tls internal

	import healthz_native

	# Seller panel + transparency endpoint
	reverse_proxy core-svc:8080
}

# ─── Dev: web.localhost — Flutter Web storefront (ADR-0005) ───────────────────
# Serves the local `flutter build web` output (mounted at /srv/web). Run
# `make web-build` first. SPA fallback to index.html.
web.localhost {
	tls internal

	import healthz_native
	root * /srv/web
	encode gzip zstd
	try_files {path} /index.html
	file_server
}

# ─── Plain HTTP: localhost:80 ────────────────────────────────────────────────
# Explicit port disables Caddy auto-HTTPS for this block. Used by the Docker
# healthcheck (wget -qO- http://localhost/healthz) and plain-HTTP smoke tests.
# NOTE: caddy fmt v2.11.x strips this block — known formatter bug (not runtime).
# caddy validate reports "Valid configuration"; the block runs correctly at runtime.
localhost:80 {
	handle /healthz {
		respond "OK" 200
	}

	@fin path /wallet/* /cashback/* /payouts/* /admin/*
	handle @fin {
		reverse_proxy fin-svc:8081
	}

	@jobs path /jobs/*
	handle @jobs {
		reverse_proxy jobs-svc:8080
	}

	# PSP webhooks fall through to the catch-all (localhost:80 has no middleware).
	handle {
		reverse_proxy core-svc:8080
	}
}

