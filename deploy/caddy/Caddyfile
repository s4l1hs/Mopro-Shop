# ─── Snippets (imported by production + dev site blocks) ─────────────────────

# Native Caddy health endpoint — does NOT proxy to any backend.
# Used by Docker healthcheck and smoke tests.
(healthz_native) {
	handle /healthz {
		respond "OK" 200
	}
}

# fin-svc owns: wallet reads, cashback reads, payout reads, admin
# ARCHITECTURE.md § 4.2 — fin-svc HTTP server: wallet/cashback/payout read
(fin_routes) {
	handle /v1/wallet/* {
		reverse_proxy fin-svc:8080
	}
	handle /v1/cashback/* {
		reverse_proxy fin-svc:8080
	}
	handle /v1/payouts/* {
		reverse_proxy fin-svc:8080
	}
	handle /v1/admin/* {
		reverse_proxy fin-svc:8080
	}
}

# jobs-svc owns: notifications, media, support, sizefinder, antifraud-inference
(jobs_routes) {
	handle /v1/jobs/* {
		reverse_proxy jobs-svc:8080
	}
}

# ─── Production: api.moproshop.com ───────────────────────────────────────────
api.moproshop.com {
	# TODO(production): CloudFlare-only enforcer.
	# Reject requests that do not carry CF-Connecting-IP (traffic that bypassed
	# CloudFlare and hit the VDS IP directly). UFW must also block direct :80/:443
	# access from non-CF IPs. Uncomment after verifying CF IP ranges.
	# @not_cf {
	#     not header CF-Connecting-IP *
	# }
	# respond @not_cf "Forbidden" 403

	import healthz_native
	import fin_routes
	import jobs_routes

	# ── PSP payment webhooks ──────────────────────────────────────────────────
	# /v1/payments/webhook/{sipay,craftgate,iyzico} → core-svc (default catch-all)
	# Signature verification: provider-specific inside /internal/payment/<provider>/
	# Sipay:      hash_key = base64(hmacSha256(rawBody, app_secret))
	# Craftgate:  x-craftgate-signature = hmacSha256(rawBody, webhook_secret)
	# iyzico:     no header signature; verify via paymentId lookup

	# ── Shipping carrier webhooks ─────────────────────────────────────────────
	# /v1/shipping/webhook/{aras,yurtici,surat,mng,hepsijet,ptt} → core-svc (default)
	# "delivered" status from any carrier updates delivered_at and triggers the
	# ecom.order.delivered.v1 event → cashback + payout unlock. (ARCHITECTURE.md § 5)

	# ── Seller transparency endpoint ──────────────────────────────────────────
	# GET /api/v1/seller/orders/:id/breakdown → core-svc (default catch-all)
	# Returns: gross, commission, KDV, net breakdown per CLAUDE.md § 4.8

	# TODO(Phase 1.5): caddy-ratelimit plugin required (xcaddy custom build).
	# rate_limit {
	#     zone api_per_ip {
	#         key     {client_ip}
	#         window  1m
	#         max     600
	#     }
	# }

	# Default: all /v1/* and /api/* not matched above → core-svc
	reverse_proxy core-svc:8080
}

# ─── Production: seller.moproshop.com ────────────────────────────────────────
seller.moproshop.com {
	# TODO(production): CloudFlare-only enforcer (same pattern as api block above)

	import healthz_native

	# Seller panel SPA + transparency endpoints (ARCHITECTURE.md § 6)
	# Primary: GET /api/v1/seller/orders/:id/breakdown  (CLAUDE.md § 4.8)
	reverse_proxy core-svc:8080
}

