[Unit]
Description=Hourly Mopro DB snapshot timer
Requires=mopro-snapshot.service

[Timer]
# Hourly — provides up to 48 local recovery points (2-day retention).
OnCalendar=hourly
# Small jitter so multiple VDSes don't hammer storage simultaneously.
RandomizedDelaySec=120
Persistent=true

[Install]
WantedBy=timers.target
