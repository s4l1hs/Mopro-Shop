#!/bin/sh
# pre-commit: refuse commits when HEAD is on a protected default branch,
# then delegate to the project's api-gen-sync check.
#
# Why the protected-branch guard: the Session 4a turn had an orphan commit
# land on local `main` because the workflow lost track of HEAD mid-session.
# The guard makes that foot-gun noisy — you have to explicitly switch to a
# feature branch before committing.
#
# Bypass (genuinely unusual cases only): `git commit --no-verify`.

set -e

PROTECTED="main master"
current_branch=$(git symbolic-ref --short -q HEAD || echo "DETACHED")

for protected in $PROTECTED; do
  if [ "$current_branch" = "$protected" ]; then
    printf '\033[0;31m❌ refusing to commit on %s\033[0m\n' "$current_branch" >&2
    printf '   checkout a feature branch first:\n' >&2
    printf '     git checkout -b feat/your-change\n' >&2
    printf '     git commit ...\n' >&2
    printf '   (or pass --no-verify if you really mean it.)\n' >&2
    exit 1
  fi
done

# ── Empty-file guard under .githooks/ ──────────────────────────────────────
#
# Why: Session 4b accidentally created an empty `mobile/.githooks/pre-commit`
# from a misplaced `touch` (the agent's cwd had drifted into `mobile/`). An
# empty hook script that gets sourced as a hook does nothing — silent
# bypass. This refuses to commit any 0-byte file under `.githooks/` so the
# foot-gun stays loud.

EMPTY_HOOKS=$(git diff --cached --name-only --diff-filter=AM | grep '^\.githooks/' || true)
for f in $EMPTY_HOOKS; do
  # `wc -c` on a non-existent file would fail under set -e; guard with -f.
  if [ -f "$f" ] && [ ! -s "$f" ]; then
    printf '\033[0;31m❌ refusing to commit empty file: %s\033[0m\n' "$f" >&2
    printf '   remove it or populate it before committing.\n' >&2
    exit 1
  fi
done

# ── api-gen sync check (existing behavior preserved) ────────────────────────

SPEC_STAGED=$(git diff --cached --name-only | grep '^api/openapi.yaml' || true)

if [ -z "$SPEC_STAGED" ]; then
  exit 0
fi

echo "[pre-commit] openapi.yaml staged — checking generated files are also staged..."

GENERATED_STAGED=$(git diff --cached --name-only | grep -E '^(internal/api/gen/|mobile/packages/mopro_api/)' || true)

if [ -z "$GENERATED_STAGED" ]; then
  echo ""
  echo "ERROR: api/openapi.yaml is staged but generated files are not."
  echo "Run 'make api-gen' and stage the output before committing:"
  echo "  make api-gen"
  echo "  git add internal/api/gen/ mobile/packages/mopro_api/"
  echo ""
  exit 1
fi

echo "[pre-commit] Generated files are staged. OK."
exit 0
