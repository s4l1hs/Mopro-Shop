# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env.local for local development.
# NEVER commit real secrets. NEVER copy production values here.
# Production secrets live in /opt/mopro/.env (chmod 600, root-only).
# ─────────────────────────────────────────────────────────────────────────────

# DB passwords — local only
ECOM_DB_PASSWORD=REPLACE_ME
LEDGER_DB_PASSWORD=REPLACE_ME
IDENTITY_DB_PASSWORD=REPLACE_ME
CATALOG_DB_PASSWORD=REPLACE_ME
CART_DB_PASSWORD=REPLACE_ME
ORDER_DB_PASSWORD=REPLACE_ME
PAYMENT_DB_PASSWORD=REPLACE_ME
SELLER_DB_PASSWORD=REPLACE_ME
SEARCH_DB_PASSWORD=REPLACE_ME
WALLET_DB_PASSWORD=REPLACE_ME
COMMISSION_DB_PASSWORD=REPLACE_ME
TREASURY_DB_PASSWORD=REPLACE_ME
CASHBACK_DB_PASSWORD=REPLACE_ME
SELLERPAYOUT_DB_PASSWORD=REPLACE_ME
NOTIFICATION_DB_PASSWORD=REPLACE_ME
SUPPORT_DB_PASSWORD=REPLACE_ME
MEDIA_DB_PASSWORD=REPLACE_ME
SIZEFINDER_DB_PASSWORD=REPLACE_ME
ANTIFRAUD_DB_PASSWORD=REPLACE_ME
EINVOICE_DB_PASSWORD=REPLACE_ME

# Redis
REDIS_PASSWORD=REPLACE_ME

# Meilisearch
MEILI_MASTER_KEY=REPLACE_ME

# Caddy
CADDY_EMAIL=REPLACE_ME

# JWT
JWT_SIGNING_KEY=REPLACE_ME

# PII encryption
PII_KEK_BASE64=REPLACE_ME
PII_PEPPER=REPLACE_ME

# Market & Localization (TR launch defaults)
MARKET=TR
DEFAULT_CURRENCY=TRY
DEFAULT_LOCALE=tr-TR
DATA_REGION=eu-central-1

# Coin issuance jurisdiction (filled in once licensed)
COIN_LICENSE_JURISDICTION=          # 'AE-DXB' | 'LT' | 'EE' | 'MT' | empty=pre-license
COIN_LICENSE_AUTHORITY=             # 'VARA' | 'B-EMI' | 'EFSA' | 'MFSA' | empty

# Cashback parameters — v6 LOCKED MODEL (do NOT change in env; constitution-level)
# Plan is perpetual; reference rate is 5000 bps (%50) hardcoded as cashback.ReferenceInterestRateBpsConst

# Seller payout parameters — v6 LOCKED MODEL
# Delay = 3 business days (hardcoded const sellerpayout.PayoutDelayBusinessDays)

# PSP (sandbox creds in dev)
PSP_PROVIDER=sipay                  # sipay | craftgate | iyzico (TR launch)
                                    # stripe | mollie | adyen (EU, Phase 7+)
PSP_API_KEY=REPLACE_ME
PSP_SECRET=REPLACE_ME
PSP_MERCHANT_ID=REPLACE_ME
PSP_WEBHOOK_SECRET=REPLACE_ME

# Shipping providers (TR launch)
SHIPPING_DEFAULT=aras               # aras | yurtici | surat | mng | hepsijet | ptt
ARAS_API_KEY=REPLACE_ME
YURTICI_API_KEY=REPLACE_ME
SURAT_API_KEY=REPLACE_ME
MNG_API_KEY=REPLACE_ME
HEPSIJET_CLIENT_ID=REPLACE_ME
HEPSIJET_CLIENT_SECRET=REPLACE_ME
PTT_API_KEY=REPLACE_ME

# Backblaze B2 (optional in dev; use minio for fully offline)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=mopro-backups
RESTIC_PASSWORD=

# Grafana Cloud (optional in dev)
GRAFANA_PROM_USER=
GRAFANA_PROM_PASS=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_PASS=
GRAFANA_TEMPO_USER=
GRAFANA_TEMPO_PASS=

# Redis Streams MAXLEN — per-stream override (ADR-0003).
# Default: 10000 for all streams.
# Formula: REDIS_STREAM_MAXLEN_<STREAM_UPPER_DOTS_TO_UNDERSCORES>=<value>
# Production recommendations (at ~100 orders/min):
#   Financial trigger streams: 25000 (~4 hours buffer)
#   Notification streams:      10000 (~1.6 hours buffer)
# If a consumer is offline longer than the buffer window, use:
#   mopro outbox replay --since "<outage-start>"  (Phase 3.3)
REDIS_STREAM_MAXLEN_ECOM_ORDER_DELIVERED_V1=25000
REDIS_STREAM_MAXLEN_ECOM_PAYMENT_CAPTURED_V1=25000
REDIS_STREAM_MAXLEN_FIN_CASHBACK_PAYMENT_POSTED_V1=10000
REDIS_STREAM_MAXLEN_FIN_SELLER_PAYOUT_POSTED_V1=10000

# Healthchecks (optional in dev — leave blank to disable)
# All HEALTHCHECK_* values are bare UUIDs from healthchecks.io (e.g. "12345678-…-abc").
# pkg/healthcheck.NewFromUUID builds the full https://hc-ping.com/<uuid> URL at runtime.
# Leave blank to disable pinging (NewFromUUID returns a no-op Pinger when empty).
HEALTHCHECK_BACKUP_UUID=
HEALTHCHECK_RESTORE_UUID=
HEALTHCHECK_DISK_HYGIENE_UUID=
HEALTHCHECK_LEDGER_RECONCILE_UUID=
HEALTHCHECK_CASHBACK_CRON_UUID=
HEALTHCHECK_SELLER_PAYOUT_CRON_UUID=

# Slack/PagerDuty (optional in dev — leave blank to disable alerts)
SLACK_WEBHOOK=
SLACK_PANIC_WEBHOOK=
PAGERDUTY_API=
PAGERDUTY_ROUTING_KEY=
RECONCILE_DATABASE_URL=
LEDGER_RECONCILE_DRY_RUN=false
LEDGER_RECONCILE_TZ=Europe/Istanbul
BETTERSTACK_INCIDENT_API=

# Admin internal token (for cron-to-fin-svc admin endpoints)
ADMIN_INTERNAL_TOKEN=REPLACE_ME
