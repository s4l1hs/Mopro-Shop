# =============================================================================
# Mopro Shop — .env.example (AUTHORITATIVE TEMPLATE — placeholders only)
# =============================================================================
# Every var below traces to a real env read in cmd/ or internal/ (Go), grouped by
# concern. Copy to /etc/mopro/.env (chmod 600, root-only — CLAUDE.md §6), fill the
# __FILL_ME__ placeholders with real provider credentials, and NEVER commit the
# filled .env (it is gitignored via `.env*`).
#
# Values shown bare (e.g. MARKET=TR) are non-secret launch config — adjust per env.
# __FILL_ME__ marks a secret/endpoint you must supply. Test-only vars (*_TEST_DSN,
# REDIS_TEST_*, GOPTER_SEED, …) are intentionally OMITTED — they belong to the test
# harness, not a runtime env.
#
# ⚠️ KNOWN VAR-NAMING SPLITS (flagged, NOT silently normalised — verify before fill):
#   • Sipay key: core-svc reads SIPAY_MERCHANT_KEY; fin-svc reads SIPAY_APP_KEY.
#     Confirm whether these are the SAME Sipay secret under two names or two distinct
#     credentials (Sipay "merchant key" vs "app key" are different concepts).
#   • Prod signal: ENV=production gates the OTP dev-bypass guard; GO_ENV=production
#     gates Sipay + shipping prod mode. BOTH must be "production" in prod.
#   • Search/Meilisearch: NO env vars are read by the code (internal/search has zero
#     Getenv). The brief assumed a Meili host+master-key block — there is none to
#     template; do not invent one. (Search host is wired elsewhere / hardcoded.)
# =============================================================================

# --- Service / runtime -------------------------------------------------------
ENV=production                 # OTP-bypass prod guard (see split above); use "dev" locally
GO_ENV=production              # Sipay + shipping prod mode (see split above)
LOG_LEVEL=info                 # slog level
MARKET=TR                      # launch market (CLAUDE.md); read via mustEnv
DEFAULT_CURRENCY=TRY           # fiat ISO code (mustEnv)
DEFAULT_CASHBACK_CURRENCY=TRY_COIN  # coin currency (mustEnv)
DEFAULT_LOCALE=tr-TR
EXTRA_MARKETS=                 # optional CSV of additional markets
CASHBACK_CRON_MARKETS=         # optional CSV; markets the cashback cron runs for
WEB_BASE_URL=https://moproshop.com           # public web origin (links/emails)
JOBS_SVC_URL=http://jobs-svc:8082            # core-svc → jobs-svc internal base (§3.4)
ADMIN_INTERNAL_TOKEN=__FILL_ME__             # shared secret for core↔jobs internal calls (X-Internal-Token)
OTEL_EXPORTER_OTLP_ENDPOINT=                 # optional OTLP collector; empty disables export

# --- Database (PgBouncer) -----------------------------------------------------
# Two connection styles by consumer (heterogeneous — documented, not normalised):
#  • core-svc (ecom): assembled from PgBouncer host/port + password, OR full CATALOG_DSN override.
#  • fin-svc (ledger), jobs-svc (ecom schemas), migrate-tool: full *_DATABASE_URL.
PGBOUNCER_ECOM_HOST=pgbouncer-ecom           # core-svc ecom pool host
PGBOUNCER_ECOM_PORT=6432                      # core-svc ecom pool port
ECOM_DB_PASSWORD=__FILL_ME__                  # core-svc ecom DB password (user/dbname have in-code defaults)
CATALOG_DSN=                                  # optional full DSN; overrides the assembled ecom DSN when set
ECOM_DATABASE_URL=__FILL_ME__                 # migrate-tool (ecom) full URL: postgres://user:pass@host:port/db?sslmode=...
NOTIFICATION_DATABASE_URL=__FILL_ME__         # jobs-svc (ecom schemas) + migrate-tool full URL
LEDGER_DATABASE_URL=__FILL_ME__               # fin-svc (ledger) + migrate-tool full URL (mustEnv in fin-svc)
RECONCILE_DATABASE_URL=__FILL_ME__            # fin reconcile worker full URL
DLQ_DATABASE_URL=__FILL_ME__                  # DLQ tooling (cmd/mopro) full URL
MIGRATIONS_DIR=                               # optional override for migrate-tool migrations path

# --- Cache / Streams (Redis) --------------------------------------------------
REDIS_ADDR=redis:6379          # host:port (mustEnv in jobs/fin/mopro; canonical — NOT REDIS_URL)
REDIS_PASSWORD=__FILL_ME__     # Redis AUTH password

# --- Crypto / PII (CLAUDE.md §6) ---------------------------------------------
PII_KEK_BASE64=__FILL_ME__     # base64 AES-GCM key-encryption-key for EncryptPII (32 bytes → base64)
PII_PEPPER=__FILL_ME__         # pepper for PII hashing/lookup
JWT_SIGNING_KEY=__FILL_ME__    # JWT HMAC signing key (mustEnv)

# --- Payments (Sipay; PSP adapter) -------------------------------------------
PSP_PROVIDER=sipay             # active PSP adapter (CLAUDE.md §9)
SELLERPAYOUT_PSP_MODE=         # fin-svc payout mode; empty → "shadow" (no live transfer)
SIPAY_BASE_URL=__FILL_ME__     # Sipay API base (mustEnv)
SIPAY_APP_ID=__FILL_ME__       # Sipay app id (mustEnv core)
SIPAY_APP_SECRET=__FILL_ME__   # Sipay app secret (mustEnv core)
SIPAY_MERCHANT_ID=__FILL_ME__  # Sipay merchant id (mustEnv core)
SIPAY_MERCHANT_KEY=__FILL_ME__ # Sipay key — core-svc payment client (see naming-split note)
SIPAY_APP_KEY=__FILL_ME__      # Sipay key — fin-svc payout client (see naming-split note)
SIPAY_RETURN_URL=https://moproshop.com/checkout/return   # optional 3DS return URL
SIPAY_CANCEL_URL=https://moproshop.com/checkout/cancel   # optional 3DS cancel URL

# --- Storage (object store for RT-03 review photos + avatars) -----------------
# internal/storage is a GENERIC S3-compatible client: STORAGE_BACKEND="fs" → local
# filesystem (dev/test); ANY OTHER value → S3 API. So Backblaze B2 (its S3 endpoint)
# OR Cloudflare R2 both work through these same vars — no provider-specific code.
# Backblaze B2-direct example values shown in comments; fill with real creds.
STORAGE_ENABLED=true                          # "true" enables uploads; anything else 503s the upload route
STORAGE_BACKEND=s3                            # "fs" = local dev; non-"fs" = S3-compatible (B2/R2)
PHOTO_STORAGE_PATH=                           # only used when STORAGE_BACKEND=fs (local dir)
STORAGE_ENDPOINT=__FILL_ME__                  # B2: https://s3.<region>.backblazeb2.com  | R2: https://<acct>.r2.cloudflarestorage.com
STORAGE_REGION=__FILL_ME__                    # B2: e.g. us-west-004 | R2: auto
STORAGE_BUCKET=__FILL_ME__                    # bucket name
STORAGE_ACCESS_KEY=__FILL_ME__                # B2: keyID | R2: access-key-id
STORAGE_SECRET_KEY=__FILL_ME__                # B2: applicationKey | R2: secret-access-key
CDN_BASE_URL=__FILL_ME__                      # public base URL for serving objects (e.g. CDN/CloudFlare in front of the bucket)

# --- OTP / SMS / Notification -------------------------------------------------
# Prod login OTP requires SMS_PROVIDER=netgsm + the NETGSM creds. Empty/"mock" →
# mock sender (logs OTP, no delivery) → DO NOT use in prod (login won't deliver).
# (The DEV_OTP_ACCEPT_ANY dev backdoor is intentionally NOT in this template — it is
#  dev-only and hard-guarded: the service PANICS if it is true while ENV=production.)
SMS_PROVIDER=netgsm            # "netgsm" for prod; empty/"mock" for dev only
NETGSM_USERNAME=__FILL_ME__    # NetGSM account (mustEnv when provider=netgsm)
NETGSM_PASSWORD=__FILL_ME__    # NetGSM password (mustEnv when provider=netgsm)
NETGSM_HEADER=__FILL_ME__      # NetGSM approved sender header (mustEnv when provider=netgsm)
NETGSM_API_URL=                # optional NetGSM API base override

# --- Observability / alerting -------------------------------------------------
PAGERDUTY_API=__FILL_ME__              # PagerDuty API (mustEnv where used)
PAGERDUTY_ROUTING_KEY=__FILL_ME__      # PagerDuty Events routing key
SLACK_PANIC_WEBHOOK=__FILL_ME__        # Slack webhook for SMS/panic alerts (empty = no-op)
SLACK_DLQ_WEBHOOK_URL=__FILL_ME__      # Slack webhook for fin-svc DLQ alerts (empty = no-op)
SLACK_RECONCILE_WEBHOOK=__FILL_ME__    # Slack webhook for ledger-reconcile alerts (empty = no-op)
HEALTHCHECK_CASHBACK_CRON_UUID=        # healthchecks.io ping UUID (optional)
HEALTHCHECK_LEDGER_RECONCILE_UUID=     # healthchecks.io ping UUID (optional)
HEALTHCHECK_SELLER_PAYOUT_CRON_UUID=   # healthchecks.io ping UUID (optional)
LEDGER_RECONCILE_DRY_RUN=              # "true" = reconcile reports without writing

# --- Shipping carriers (adapter pattern; fill only the ones you use) ---------
KARGO_DEFAULT=                 # default carrier code
RETURN_CARRIER=                # carrier used for return labels (RT-02)
ARAS_BASE_URL=
ARAS_USERNAME=__FILL_ME__
ARAS_PASSWORD=__FILL_ME__
ARAS_CUSTOMER_CODE=__FILL_ME__
SURAT_BASE_URL=
SURAT_USERNAME=__FILL_ME__
SURAT_PASSWORD=__FILL_ME__
SURAT_WEBHOOK_SECRET=__FILL_ME__
MNG_BASE_URL=
MNG_API_KEY=__FILL_ME__
MNG_WEBHOOK_SECRET=__FILL_ME__
YURTICI_WSDL_URL=
YURTICI_USERNAME=__FILL_ME__
YURTICI_PASSWORD=__FILL_ME__
YURTICI_CUSTOMER_CODE=__FILL_ME__
PTT_WSDL_URL=
PTT_USERNAME=__FILL_ME__
PTT_PASSWORD=__FILL_ME__
PTT_CUSTOMER_CODE=__FILL_ME__
HEPSIJET_BASE_URL=
HEPSIJET_CLIENT_ID=__FILL_ME__
HEPSIJET_CLIENT_SECRET=__FILL_ME__
HEPSIJET_WEBHOOK_TOKEN=__FILL_ME__
