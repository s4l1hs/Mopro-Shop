# Web frontend — copy to .env.local for local development
# NEVER commit real secrets.

# Backend API — internal server-to-server URL (private network, no CloudFlare).
# Used by Next.js server routes (API routes, Server Components).
# For local dev this is the same as API_BASE_URL.
API_BASE_URL_INTERNAL=http://localhost:8080

# Backend API (fallback; used server-side only)
API_BASE_URL=http://localhost:8080

# Public API base (used client-side for direct calls)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Public site URL (used for canonical URLs, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cookie secret for signing the session indicator (min 32 chars)
COOKIE_SECRET=REPLACE_ME_32_CHARS_MIN_XXXXXXXXXXXXXX

# Vercel Analytics (optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
