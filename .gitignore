# Secrets — NEVER commit
.env*

# Local data volumes (populated by docker compose)
/data/

# Temp build artefacts
/tmp/

# Go
/vendor/
*.test
coverage.out
*.out
*.coverprofile
profile.cov

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Compiled binaries at repo root (use /tmp/ per Makefile build targets)
/core-svc
/fin-svc
/jobs-svc
/migrate-tool
/mopro

# IDE
.DS_Store
.idea/
.vscode/

# go.work.sum (generated; go.work itself is committed — needed to override parent workspace)
go.work.sum

# Docker overrides
docker-compose.override.yml
bin/
*.bak

# Editor temp files
*.orig
*.swp
*~

# Claude Code runtime state (session locks, workspace state — not project state)
.claude/

# Load test secrets and generated outputs
load-tests/.tokens.json
load-tests/.refresh.json
load-tests/.otps.json
load-tests/reports/*.json
load-tests/reports/*.md
!load-tests/reports/README.md
!load-tests/reports/.gitkeep

# Flutter golden test failure captures (transient)
**/test/**/failures/

# §2 image normalization local safety net (never committed)
mobile/assets/images/_originals/
