<?xml version="1.0" encoding="utf-8"?>
<!--
  Exclude all FlutterSecureStorage entries from Android Auto Backup and
  cloud data extraction. Token storage keys written by flutter_secure_storage
  use the shared-preferences domain with the app package prefix.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="FlutterSecureStorage" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="FlutterSecureStorage" />
    </device-transfer>
</data-extraction-rules>
